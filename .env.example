# Environment: dev | prod
APP_ENV=dev

# Database (MySQL)
DB_HOST=mysql
DB_PORT=3306
DB_USER=manhes
DB_PASS=manhes
DB_NAME=manhes

# Ingestion
INGEST_INTERVAL=30m
INGEST_WORKERS=5
SYNC_INTERVAL=15m
DOWNLOADER_TIMEOUT=30s

# S3
S3_ENDPOINT=minio:9000
S3_BUCKET=manga
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_PUBLIC_ENDPOINT=localhost:9000

# Kafka / Redpanda
KAFKA_BROKERS=redpanda:9092

# Scrapers
MANGADEX_BASE_URL=https://api.mangadex.org
MANGADEX_RATE_LIMIT=5

ATSU_BASE_URL=https://atsu.moe
ATSU_RATE_LIMIT=3
